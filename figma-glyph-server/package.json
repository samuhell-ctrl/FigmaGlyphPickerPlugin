{
  "name": "figma-glyph-server",
  "version": "1.1.1",
  "description": "Headless tray app that runs the Figma Glyph Express font server",
  "main": "main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/samuhell-ctrl/FigmaGlyphPickerPlugin.git"
  },
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "electron-updater": "^6.1.8",
    "express": "^5.2.1",
    "get-system-fonts": "^2.0.2",
    "opentype.js": "^1.3.4"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "electron": "^40.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.yourname.figma-glyph-font-server",
    "productName": "Figma Glyph Font Server",
    "publish": {
      "provider": "github",
      "owner": "samuhell-ctrl",
      "repo": "FigmaGlyphPickerPlugin"
    },
    "files": [
      "main.js",
      "server.js",
      "package.json",
      "node_modules/**"
    ],
    "asar": true,
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "extendInfo": {
        "LSUIElement": true
      },
      "category": "public.app-category.developer-tools",
      "artifactName": "${productName}-mac-${version}.${ext}"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "artifactName": "${productName}-win-${version}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}